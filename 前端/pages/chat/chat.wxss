.chat-page {
    background-color: #f8f8f8;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}

.chat-messages {
    flex: 1;
    padding: 20rpx;
    padding-bottom: 120rpx;
}

.message-item {
    margin-bottom: 30rpx;
    display: flex;
}

.message-item.sent {
    justify-content: flex-end;
}

.message-item.received {
    justify-content: flex-start;
}

.message-content {
    max-width: 70%;
    padding: 20rpx;
    border-radius: 20rpx;
    position: relative;
}

.sent .message-content {
    background-color: #1E941D;
    color: #fff;
}

.received .message-content {
    background-color: #fff;
    color: #333;
}

.message-text {
    font-size: 28rpx;
    line-height: 1.4;
    word-wrap: break-word;
}

.message-time {
    font-size: 22rpx;
    opacity: 0.7;
    margin-top: 10rpx;
    display: block;
}

.chat-input-section {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background-color: #fff;
    border-top: 1rpx solid #f0f0f0;
    padding: 20rpx 30rpx;
    padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.input-container {
    display: flex;
    align-items: center;
    background-color: #f8f8f8;
    border-radius: 40rpx;
    padding: 0 20rpx;
}

.message-input {
    flex: 1;
    height: 80rpx;
    font-size: 28rpx;
    color: #333;
}

.send-btn {
    background-color: #1E941D;
    color: #fff;
    border: none;
    border-radius: 30rpx;
    padding: 0 30rpx;
    height: 60rpx;
    line-height: 60rpx;
    font-size: 28rpx;
    margin-left: 20rpx;
}

.send-btn:active {
    background-color: #167a16;
} 